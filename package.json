{
  "name": "storyos",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "docs:check": "node scripts/check-doc-links.mjs",
    "license:check": "node scripts/license-check.mjs",
    "db:migrate": "pnpm --filter @storyos/api db:migrate",
    "db:generate": "pnpm --filter @storyos/api db:generate",
    "sdk:generate": "pnpm --filter @storyos/api openapi:generate && pnpm --filter @storyos/sdk generate && pnpm --filter @storyos/sdk build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
