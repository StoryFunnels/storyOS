# Copy to .env for local development (defaults match docker-compose.dev.yml)
DATABASE_URL=postgres://storyos:storyos@localhost:5432/storyos
PORT=3001

# Public URLs
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# Auth — REQUIRED in production. Leave blank for local dev (a random per-boot
# secret is generated). Production refuses to boot without a strong value:
#   BETTER_AUTH_SECRET=$(openssl rand -hex 32)
BETTER_AUTH_SECRET=

# Google OAuth (optional — login button hidden when unset)
# Redirect URI to register: {API_URL}/api/v1/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# YOUTUBE_DAILY_QUOTA_UNITS=10000

# GitHub App (optional — the "Connect GitHub" + repo picker + PR backlink of #247).
# All four ABSENT → the Connect feature is simply unavailable and boot is
# unaffected; the manual per-workspace webhook secret + PAT path still works.
# Register a GitHub App, then set:
#   Callback URL to register: {API_URL}/api/v1/integrations/github/oauth/callback
# GITHUB_APP_ID=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# The private key (PEM), two supported forms — pick one:
#   1) inline: paste the PEM on a single line with literal \n between lines
#      (dotenv can't hold real newlines; we expand \n before signing):
#      GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
#   2) file (preferred for Docker-secret deploys that mount the PEM):
#      GITHUB_APP_PRIVATE_KEY_FILE=/run/secrets/github_app_private_key
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_PRIVATE_KEY_FILE=
# The App's ONE webhook secret (set at App registration, instance-level). When
# set, every inbound delivery is verified against it and the workspace is resolved
# from the payload's installation.id — no per-workspace secret, no PAT. Absent →
# the legacy per-workspace webhook secret path is used. Never commit a real value.
#   GITHUB_APP_WEBHOOK_SECRET=whsec_...
# GITHUB_APP_WEBHOOK_SECRET=

# Email (MN-103): Resend's HTTP API is preferred when RESEND_API_KEY is set.
# RESEND_API_KEY=re_your_resend_api_key_here

# SMTP (fallback — used only when RESEND_API_KEY is unset; emails are logged
# when neither is set).
# Dev: Mailpit from docker-compose.dev.yml catches everything at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# Production example (Resend over SMTP instead of its HTTP API):
#   SMTP_HOST=smtp.resend.com SMTP_PORT=465 SMTP_USER=resend SMTP_PASS=re_...
MAIL_FROM=StoryOS <noreply@storyos.local>
