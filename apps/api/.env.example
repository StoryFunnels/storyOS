# Copy to .env for local development (defaults match docker-compose.dev.yml)
DATABASE_URL=postgres://storyos:storyos@localhost:5432/storyos
PORT=3001

# Public URLs
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# Auth — REQUIRED in production. Leave blank for local dev (a random per-boot
# secret is generated). Production refuses to boot without a strong value:
#   BETTER_AUTH_SECRET=$(openssl rand -hex 32)
BETTER_AUTH_SECRET=

# Google OAuth (optional — login button hidden when unset)
# Redirect URI to register: {API_URL}/api/v1/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# SMTP (optional — emails are logged when unset).
# Dev: Mailpit from docker-compose.dev.yml catches everything at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# Production example (Resend): SMTP_HOST=smtp.resend.com SMTP_PORT=465 SMTP_USER=resend SMTP_PASS=re_...
MAIL_FROM=StoryOS <noreply@storyos.local>
