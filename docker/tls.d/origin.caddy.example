# Origin TLS for Cloudflare "Full (strict)" mode.
#
# Copy this file to `origin.caddy` (same directory) ON YOUR SERVER ONLY, then
# place a Cloudflare Origin CA certificate + key at:
#   docker/certs/origin.pem   — the Origin Certificate
#   docker/certs/origin.key   — the Private Key
#
# Generate them in Cloudflare → SSL/TLS → Origin Server → Create Certificate
# (hostnames: your-domain.com, *.your-domain.com; 15-year validity is fine).
# NEVER commit origin.caddy or the certs — they are gitignored on purpose.
#
# `:443` with an explicit cert makes Caddy present it for every hostname without
# ACME, so it works behind Cloudflare's proxy. Then set the zone's SSL/TLS mode
# to "Full (strict)".
:443 {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key

	# Hosted MCP on its own subdomain. Change mcp.example.com to YOUR domain
	# (e.g. mcp.storyos.dev) and add an A record for it. Remove this block if
	# you're not running the mcp service.
	@mcp host mcp.example.com
	handle @mcp {
		reverse_proxy mcp:3002
	}

	# OAuth authorization-server discovery at the ROOT (RFC 8414 / MN-154). better-auth's
	# issuer is the app origin, so clients (claude.ai) look for the metadata here — proxy
	# it to better-auth under /api/v1/auth. Needed for hosted-MCP OAuth connectors.
	handle /.well-known/oauth-authorization-server {
		rewrite * /api/v1/auth/.well-known/oauth-authorization-server
		reverse_proxy api:3001
	}
	handle /.well-known/openid-configuration {
		rewrite * /api/v1/auth/.well-known/openid-configuration
		reverse_proxy api:3001
	}

	# App: API + web on the main host(s).
	handle /api/* {
		reverse_proxy api:3001
	}
	handle {
		reverse_proxy web:3000
	}
}
