# StoryOS — self-host environment (docker compose reads this file as `.env`).
# Copy to `.env` and fill in. NEVER commit the real `.env` (it's gitignored).

# --- URLs (public origins) ---
# Same-origin deploy: point both at your app hostname; leave NEXT_PUBLIC_API_URL empty.
API_URL=https://app.storyos.dev
WEB_URL=https://app.storyos.dev
NEXT_PUBLIC_API_URL=

# --- Auth ---
# REQUIRED in production — the API refuses to boot without a strong value.
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Optional Google OAuth (leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Managed StoryOS AI ---
# Server-side provider credential for managed agent runs and Architect proposals.
# Leave blank to disable managed AI. Your-own-AI/BYO-AI over MCP never uses or
# meters this key. Override the default model only if your account supports it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Database ---
POSTGRES_PASSWORD=storyos

# --- Reverse proxy ports (Caddy) ---
HTTP_PORT=80
HTTPS_PORT=443

# --- Email (invitations, mentions, notifications, auth verify/reset) ---
# Emails are logged (not sent) when neither RESEND_API_KEY nor SMTP_HOST is set.
# Preferred (MN-103): Resend's HTTP API — verify your domain in Resend first, then:
RESEND_API_KEY=re_your_resend_api_key_here
MAIL_FROM=StoryOS <noreply@storyos.dev>

# Alternative: any SMTP provider (used only when RESEND_API_KEY is unset), e.g.
# Resend over SMTP instead of its HTTP API:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_your_resend_api_key_here

# --- Object storage (attachments) ---
# local disk (default) or s3
STORAGE_DRIVER=local
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Billing (MN-165) ---
# All optional. Leave STRIPE_SECRET_KEY blank to disable billing entirely:
# every workspace is Free, checkout/portal 503, and the webhook no-ops. Self-host
# never needs Stripe. Use TEST keys (sk_test_/whsec_) outside production.
STRIPE_SECRET_KEY=
# Webhook signing secret. Local dev: `stripe listen --forward-to \
#   localhost:3001/api/v1/billing/webhook` prints a whsec_... — paste it here.
STRIPE_WEBHOOK_SECRET=
# Price ids come from `pnpm --filter @storyos/api billing:seed` (test mode).
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_SEAT=
# Stripe Tax is a paid add-on, off by default. Set to true only when you want to
# calculate/collect VAT/sales tax (requires activating Tax in the dashboard).
STRIPE_TAX_ENABLED=false

# --- Platform admin (MN-104/#304) ---
# Optional. On API boot, this email is granted platform-admin access
# (/admin) if a matching user already signed up — otherwise it logs a
# warning and retries on the next boot. Set it, restart the api container
# once, then manage further admins from /admin itself rather than rotating
# this var.
PLATFORM_ADMIN_EMAIL=

# --- Analytics (PostHog) ---
# Baked into the web bundle at build time (NEXT_PUBLIC_*). Optional — leave the
# token blank to disable analytics entirely. Create your own project at
# https://posthog.com (or self-host) and paste its project API key below; do
# not reuse someone else's token, it will mix your usage data into their project.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Push notifications (MN-230a) ---
# Optional. The service worker's push handling works regardless; leaving this
# blank just means the client never subscribes (generate with `npx web-push
# generate-vapid-keys` — the private half isn't needed yet, no send path exists).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
