  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "generate": "openapi-typescript ../../docs/api/openapi.json -o src/generated/schema.ts"
  },
  "devDependencies": {
    "@storyos/config": "workspace:*",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  }
}
