{
  "name": "@storyos/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "storyos-mcp": "./dist/index.js",
    "storyos-mcp-http": "./dist/http.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@storyos/config": "workspace:*",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@storyos/sdk": "workspace:*",
    "zod": "^4.4.3"
  }
}
