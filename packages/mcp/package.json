{
  "name": "@storyos/mcp",
  "version": "0.1.0",
  "description": "StoryOS Model Context Protocol server \u2014 expose your StoryOS workspace to AI agents (stdio + hosted HTTP).",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "bin": {
    "storyos-mcp": "./dist/index.js",
    "storyos-mcp-http": "./dist/http.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/StoryFunnels/storyOS.git",
    "directory": "packages/mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "storyos",
    "ai-agents"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "bundle": "esbuild src/index.ts src/http.ts src/server.ts --bundle --platform=node --format=esm --target=node20 --outdir=dist --external:@modelcontextprotocol/sdk --external:zod",
    "prepublishOnly": "pnpm build && pnpm bundle",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@storyos/config": "workspace:*",
    "@storyos/schemas": "workspace:*",
    "@storyos/sdk": "workspace:*",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
